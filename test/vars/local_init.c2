// @warnings{no-unused}
module test;

i32 gg = 10;

public fn void test1(i32 arg1) {
    static const char* str = "abc";
    static i32 a;
    static i32* aa = &gg;
    static i32 b = 10;
    static i32* c = &b;
    static i32 d = arg1;     // @error{initializer element is not a compile-time constant}
}

