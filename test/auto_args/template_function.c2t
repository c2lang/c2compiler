// @recipe bin
    $warnings no-unused
    $backend c

// @file{file1}
module test;

fn X test1(const u32 line @(auto_line), X x) template X {
    return (X)(x + line);
}

public fn i32 main() {
    i32 a = test1<i32>(20);
    return 0;
}

// @expect{atleast, cgen/build.c}
int main(void);

static int test_test1_0_(const u32 line, int x)
{
    return (int)(x + line);
}

int main(void)
{
   int a = test_test1_0_(8, 20);
   return 0;
}

