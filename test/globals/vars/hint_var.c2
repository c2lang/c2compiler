// @warnings{no-unused}
module test;

i32 aaaa;
i32 bbbb;

fn void test1() {
    aaa = 1;        // @error{use of undeclared identifier 'aaa'; did you mean 'aaaa'?}
}

fn void test2() {
    bbb = 1;    // @error{use of undeclared identifier 'bbb'; did you mean 'bbbb'?}
}

fn void test3() {
    i32 ab;
    bb = 1; // @error{use of undeclared identifier 'bb'; did you mean 'ab'?}
}

fn void test4() {
    i32 ab;
    bbb = 1;    // @error{use of undeclared identifier 'bbb'; did you mean 'bbbb'?}
}

fn void test5() {
    i32 ab;
    {
        i32 ac;
        {
            aa = 1;    // @error{use of undeclared identifier 'aa'; did you mean 'ab'?}
        }
    }
}

