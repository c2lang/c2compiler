// @recipe bin
    $warnings no-unused
    $backend c

// @file{file1}
module mod1;

fn i32 sum(i32 a, i32 b) {
    return a + b;
}

// @file{file2}
module mod2;

fn i32 sum(i32 c, i32 d) {
    return c + d;
}

// @expect{atleast, cgen/build.c}
static int mod1_sum(int a, int b);

static int mod1_sum(int a, int b)
{
    return a + b;
}

static int mod2_sum(int c, int d);

static int mod2_sum(int c, int d)
{
    return c + d;
}
