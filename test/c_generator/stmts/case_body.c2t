// @recipe bin
    $warnings no-unused
    $backend c

// @file{file1}
module test;

public fn i32 main(i32 argc, const char** argv) {
    switch (argc) {
    case 1:
        i32 a = 10;
        return a;
    case 2:
        break;
    default:
        break;
    }
    return 0;
}

fn i32 default_body(i32 arg) {
    switch (arg) {
    case 1:
        break;
    default:
        i32 a = 10;
        return a;
    }
    return 0;
}

fn void nested_body(i32 arg) {
    switch (arg) {
    case 1:
        i32 a = 10;
        switch (a) {
        case 1:
            break;
        case 2:
            break;
        }
        break;
    case 2:
        break;
    }
}

// @expect{atleast, cgen/build.c}

int main(int argc, const char** argv)
{
    switch (argc) {
    case 1: {
        int a = 10;
        return a;
    }
    case 2:
        break;
    default:
        break;
    }
    return 0;
}

static int test_default_body(int arg)
{
    switch (arg) {
    case 1:
        break;
    default: {
        int a = 10;
        return a;
     }
    }
    return 0;
}

static void test_nested_body(int arg)
{
    switch (arg) {
    case 1: {
        int a = 10;
        switch (a) {
        case 1:
            break;
        case 2:
            break;
        }
        break;
    }
    case 2:
        break;
    }
}

