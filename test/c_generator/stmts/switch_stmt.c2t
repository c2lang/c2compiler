// @recipe bin
    $warnings no-unused
    $backend c

// @file{file1}
module test;

fn void test1(i32 i) {
    switch (i) {
    case 1:
        i += 1;
        break;
    case 2:
        i += 2;
        fallthrough;
    case 3:
        i += 3;
        break;
    case 4:
        i += 4;
        break;
    case 5:
        return;
    case 6:
    default:
        i += 10;
        break;
    }
}

fn void test2(i32 i) {
    while (1) {
        switch (i) {
        case 1:
            continue;
        default:
            break;
        }
    }
}

fn void test3(i32 i) {
    switch (i) {
    case 0:
        break;
    case 1:
        i32 a = 10;
        break;
    case 2: {
        i32 b = 20;
        break;
    }
    default:
        break;
    }
}

public fn i32 main(i32 argc, const char** argv) {
    i32 a = 0;
    switch (a) {
    default:
        break;
    }

    return 0;
}

// @expect{atleast, cgen/build.c}


static void test_test1(int i)
{
    switch (i) {
    case 1:
        i += 1;
        break;
    case 2:
        i += 2;
        fallthrough;
    case 3:
        i += 3;
        break;
    case 4:
        i += 4;
        break;
    case 5:
        return;
    case 6:
    default:
        i += 10;
        break;
    }
}

static void test_test2(int i)
{
    while (1) {
        switch (i) {
        case 1:
            continue;
        default:
            break;
        }
    }
}


static void test_test3(int i)
{
   switch (i) {
   case 0:
      break;
   case 1: {
      int a = 10;
      break;
   }
   case 2:
   {
      int b = 20;
      break;
   }
   default:
      break;
   }
}

int main(int argc, const char** argv)
{
    int a = 0;
    switch (a) {
    default:
        break;
    }

    return 0;
}

