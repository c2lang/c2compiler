module sys_time extern "C";

import sys_types local; // time_t, suseconds_t

struct Timeval @(cname="timeval") {
    time_t tv_sec;
    suseconds_t tv_usec;
}
static_assert(2 * sizeof(time_t), sizeof(Timeval));

struct Timezone @(cname="timezone") {
    int tz_minuteswest;
    int tz_dsttime;
}

int gettimeofday(Timeval* tv, Timezone* tz);
int settimeofday(const Timeval* tv, const Timezone* tz);

